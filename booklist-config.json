{
  "csvDelimiter": ",",
  "paragraphStyle": "Boeklijst item",
  "insertMode": "selectedFrame",
  "emptyLineBetweenRecords": true,

  "characterStyles": {
    "title":   "Boeklijst titel",
    "field":   "Boeklijst tekst",
    "divider": "Boeklijst divider A"
