    { "text": " - ",   "style": "Boeklijst divider B" },
    { "text": "  |  ", "style": "Boeklijst divider A" },
    { "text": "  |  ", "style": "Boeklijst divider A" },
    { "text": "  |  ", "style": "Boeklijst divider A" },
    { "text": "  |  ", "style": "Boeklijst divider A" }
  ]
